{
  "name": "readme-ai-gen",
  "version": "1.0.0",
  "description": "CLI tool that scans a project and generates a professional README.md using AI or smart heuristics",
  "type": "module",
  "bin": {
    "ai-readme-gen": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "readme",
    "documentation",
    "generator",
    "cli",
    "ai",
    "markdown",
    "docs",
    "scaffold"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "fs-extra": "^11.3.4",
    "glob": "^11.1.0",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.39",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
